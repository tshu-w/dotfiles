{
  "version": 2,
  "display": {
    "alignment": "left",
    "barStyle": "percentage",
    "barType": "horizontal-single",
    "barWidth": 8,
    "barCharacter": "heavy",
    "containBar": false,
    "brailleFillEmpty": false,
    "brailleFullBlocks": false,
    "colorScheme": "base-warning-error",
    "usageColorTargets": {
      "title": true,
      "timer": true,
      "bar": true,
      "usageLabel": true,
      "status": false
    },
    "resetTimePosition": "back",
    "resetTimeFormat": "relative",
    "resetTimeContainment": "()",
    "statusIndicatorMode": "icon",
