    "providerLabel": "none",
    "providerLabelColon": false,
    "providerLabelBold": false,
    "baseTextColor": "dim",
    "backgroundColor": "none",
    "showWindowTitle": true,
    "boldWindowTitle": false,
    "showUsageLabels": false,
    "dividerCharacter": "|",
    "dividerColor": "dim",
    "dividerBlanks": 1,
    "showProviderDivider": false,
    "statusLeadingDivider": false,
    "statusTrailingDivider": false,
    "dividerFooterJoin": false,
    "showTopDivider": false,
    "showBottomDivider": false,
    "paddingLeft": 0,
    "paddingRight": 0,
    "widgetPlacement": "status",
    "showContextBar": false,
